---
// Fixed HUD: accent (amber/cyan) + scanline (hard/soft) toggles + live DSEG7 clock.
// Behaviour is wired in Base.astro's astro:page-load handler (view-transition safe).
---
<div class="hud" role="group" aria-label="theme controls">
  <button data-acc="amber" title="amber accent">amber</button>
  <button data-acc="cyan" title="cyan accent">cyan</button>
  <span class="sep2"></span>
  <button data-scan title="toggle scanlines">scan</button>
  <span class="sep2"></span>
  <span class="clk" id="clk" aria-hidden="true">00:00:00</span>
</div>
