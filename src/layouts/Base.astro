---
import '@fontsource/vt323'; // display (400 only)
import '@fontsource/geist-mono/600.css'; // hero wordmark
import '@fontsource/geist-mono/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props { title?: string; description?: string; }
const {
  title = 'navon john lukose',
  description = 'kernel dev · ctf · machine learning — the site of Navon John Lukose (Magniquick).',
} = Astro.props;

const base = import.meta.env.BASE_URL; // '/' at root, '/repo/' under a project page
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {/* Cross-origin isolation for the ./shell terminal's pyodide (SharedArrayBuffer) is
      set up on demand: the shell launcher registers coi-serviceworker.js and reloads
      only when someone actually boots the shell, so other visitors pay nothing. */}

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="navon — /blog" href={`${base}rss.xml`} />
  <meta name="generator" content={Astro.generator} />
  <ClientRouter />
</head>
<body>
  <slot />

  {/* SPA nav via ClientRouter → re-init each astro:page-load (fires on first load too) */}
  <script>
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    function initRise() {
      if (reduce) return;
      document.querySelectorAll<HTMLElement>('.rise').forEach((el, i) => {
        el.style.animationDelay = i * 40 + 'ms';
      });
    }

    // text scramble / "decode" effect (Hyperplexed-style) for [data-scramble]
    const SC_CHARS = '!#$%*+=?-_/\\|[]{}^~:;.,';
    function scrambleEl(el: HTMLElement, text: string, scale = 1) {
      const q = [] as { to: string; end: number; char: string }[];
      for (let i = 0; i < text.length; i++) {
        const start = Math.floor(Math.random() * 12 * scale);
        q.push({ to: text[i], end: start + Math.floor((10 + Math.random() * 16) * scale), char: '' });
      }
      let frame = 0;
      cancelAnimationFrame((el as any)._sc);
      (el as any)._animating = true; // lock: cleared when the decode completes below
      const tick = () => {
        let out = '';
        let done = 0;
        for (const item of q) {
          if (frame >= item.end) { done++; out += item.to; }
          else {
            if (!item.char || Math.random() < 0.28) item.char = SC_CHARS[Math.floor(Math.random() * SC_CHARS.length)];
            out += '<span class="dud">' + item.char + '</span>';
          }
        }
        el.innerHTML = out;
        frame++;
        if (done < q.length) (el as any)._sc = requestAnimationFrame(tick);
        else (el as any)._animating = false;
      };
      tick();
    }

    function initScramble() {
      document.querySelectorAll<HTMLElement>('[data-scramble]').forEach((el) => {
        const words = el.dataset.cycle ? el.dataset.cycle.split('|') : [el.dataset.text ?? el.textContent ?? ''];
        if (reduce) { el.textContent = words[0]; return; }
        if (!el.dataset.scBound) {
          el.dataset.scBound = '1';
          (el as any)._wi = 0;
          const cycle = () => {
            // ignore triggers mid-decode: a length change resizes the box under the
            // pointer, refiring mouseenter → a cascade that flips back. This lock also
            // absorbs a touch's synthetic mouseenter+click double-fire.
            if ((el as any)._animating) return;
            (el as any)._wi = ((el as any)._wi + 1) % words.length;
            scrambleEl(el, words[(el as any)._wi], 1.5); // cycle + slower decode
          };
          el.addEventListener('mouseenter', cycle); // desktop hover
          el.addEventListener('click', cycle); // touch / click
          el.style.cursor = 'pointer';
        }
        (el as any)._wi = 0;
        scrambleEl(el, words[0]); // decode-in on load
      });
    }

    document.addEventListener('astro:page-load', () => { initRise(); initScramble(); });
  </script>

  {/* oneko pixel-cat pet (self-disables under reduced-motion); recreated per nav */}
  <script src={`${base}pet/oneko.min.js`} data-cat={`${base}pet/oneko.gif`} is:inline defer data-astro-rerun></script>
</body>
</html>
