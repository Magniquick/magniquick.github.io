---
import '@fontsource/vt323'; // display (400 only)
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import ThemeHud from '../components/ThemeHud.astro';

interface Props { title?: string; description?: string; }
const {
  title = 'navon john lukose',
  description = 'kernel dev · ctf · machine learning — the site of Navon John Lukose (Magniquick).',
} = Astro.props;

const base = import.meta.env.BASE_URL; // '/' at root, '/repo/' under a project page
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="navon — /blog" href={`${base}rss.xml`} />
  <meta name="generator" content={Astro.generator} />
  <ClientRouter />
  <!-- apply saved theme before paint to avoid a flash -->
  <script is:inline>
    (function () {
      try {
        if (localStorage.getItem('accent') === 'cyan') document.documentElement.dataset.accent = 'cyan';
        if (localStorage.getItem('scan') === 'soft') document.documentElement.dataset.scan = 'soft';
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <slot />
  <ThemeHud />

  <!-- SPA nav via ClientRouter → re-init each astro:page-load (fires on first load too) -->
  <script>
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    function initRise() {
      if (reduce) return;
      document.querySelectorAll<HTMLElement>('.rise').forEach((el, i) => {
        el.style.animationDelay = i * 40 + 'ms';
      });
    }

    function initHud() {
      const root = document.documentElement;
      const accBtns = document.querySelectorAll<HTMLButtonElement>('.hud [data-acc]');
      const scanBtn = document.querySelector<HTMLButtonElement>('.hud [data-scan]');

      const cur = () => (root.dataset.accent === 'cyan' ? 'cyan' : 'amber');
      const syncAccent = () =>
        accBtns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.acc === cur())));
      const syncScan = () =>
        scanBtn?.setAttribute('aria-pressed', String(root.dataset.scan === 'soft'));

      accBtns.forEach((b) =>
        b.addEventListener('click', () => {
          if (b.dataset.acc === 'cyan') root.dataset.accent = 'cyan';
          else root.removeAttribute('data-accent');
          try { localStorage.setItem('accent', b.dataset.acc!); } catch {}
          syncAccent();
        })
      );
      scanBtn?.addEventListener('click', () => {
        const soft = root.dataset.scan === 'soft';
        if (soft) root.removeAttribute('data-scan');
        else root.dataset.scan = 'soft';
        try { localStorage.setItem('scan', soft ? 'hard' : 'soft'); } catch {}
        syncScan();
      });
      syncAccent(); syncScan();
    }

    // single clock interval; always writes to whichever #clk currently exists
    let clockStarted = false;
    function initClock() {
      if (clockStarted) return;
      clockStarted = true;
      const p = (n: number) => String(n).padStart(2, '0');
      const tick = () => {
        const c = document.getElementById('clk');
        if (!c) return;
        const d = new Date();
        c.textContent = `${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`;
      };
      tick();
      setInterval(tick, 1000);
    }

    // single clock interval survives navs (initClock is guarded); it always writes
    // to whichever #clk currently exists, so the time doesn't reset on nav.
    document.addEventListener('astro:page-load', () => { initRise(); initHud(); initClock(); });
  </script>

  <!-- oneko pixel-cat pet (self-disables under reduced-motion); recreated per nav -->
  <script src={`${base}pet/oneko.js`} data-cat={`${base}pet/oneko.gif`} is:inline data-astro-rerun></script>
</body>
</html>
